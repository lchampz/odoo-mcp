# Odoo CRM MCP Server — Configuration
# Copy this file to .env and fill in your Odoo instance details.

# The base URL of your Odoo instance (no trailing slash)
ODOO_URL=https://your-company.odoo.com

# The database name (usually your Odoo subdomain without .odoo.com)
ODOO_DATABASE=your-database-name

# Odoo login credentials (use an API key as password for better security)
ODOO_USERNAME=admin@yourcompany.com
ODOO_PASSWORD=your-api-key-or-password
